# Bot token from @BotFather
BOT_TOKEN=<your_bot_token_from_BotFather>

# Channel that users must be subscribed to before their group join request is approved.
# Use @username or a numeric id with -100 prefix: -100<channel_id>
REQUIRED_CHANNEL_ID=@<your_channel_username>

# Optional safety guard: only process join requests for this group.
# Recommended in production — prevents bot from moderating random groups.
# Must be the full supergroup id with -100 prefix.
# In Telegram UI you see "1234567890", but real id is -1000000000000.
TARGET_GROUP_ID=-100<your_group_id>
