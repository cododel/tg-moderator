# Bot token from @BotFather
BOT_TOKEN=123456:replace_me

# Channel that users must be subscribed to before their group join request is approved.
# Use @public_username or a numeric chat id like -1000000000000.
REQUIRED_CHANNEL_ID=@your_channel

# Optional safety guard: only process join requests for this group.
# Recommended in production. Must be the full supergroup id with -100 prefix.
# Example: -1000000000000 (NOT 1234567890 or -1234567890).
TARGET_GROUP_ID=-1000000000000
