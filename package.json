{
  "name": "tg-moderator",
  "version": "0.1.0",
  "description": "Telegram join-request moderator bot: approves group requests only for subscribers of a required channel.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "start:prod": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "telegram",
    "bot",
    "grammy",
    "moderation",
    "join-requests"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
